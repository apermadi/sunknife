resource_name = "test"
script/source = "extends Node2D

func _input(event):
	if event.is_action_pressed(\"reset\"):
		reset()
	
	if event.is_action_pressed(\"exit\"):
		get_tree().quit()

# resets the level
func reset():
	get_tree().change_scene_to_file(\"res://levels/test.tscn\")
"

